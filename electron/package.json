{
  "name": "hinged",
  "version": "0.0.1",
  "description": "Hinged - cross-platform stamp collection manager",
  "main": "./out/main/index.js",
  "author": "David Anderson",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "rebuild:node": "node scripts/rebuild-native.mjs node",
    "rebuild:electron": "node scripts/rebuild-native.mjs electron",
    "predev": "npm run rebuild:electron",
    "dev": "electron-vite dev",
    "prebuild": "npm run rebuild:electron",
    "build": "npm run typecheck && electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "pretest": "npm run rebuild:node",
    "test": "vitest run",
    "posttest": "npm run rebuild:electron",
    "test:watch": "npm run rebuild:node && vitest",
    "lint": "eslint . --ext .ts,.tsx",
    "postinstall": "electron-builder install-app-deps",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "better-sqlite3": "^12.4.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.1.2",
    "electron-builder": "^25.0.5",
    "electron-vite": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vitest": "^2.1.1",
    "zustand": "^5.0.0"
  }
}
